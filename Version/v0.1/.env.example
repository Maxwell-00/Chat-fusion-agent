# ===========================================================================
# Fusion Agent 配置示例
# 用法：复制本文件为 .env，再填入真实 key   ->   cp .env.example .env
# 程序从 MODEL1 开始递增扫描 MODEL{n}_NAME，直到某个序号缺失为止。
# 所有模型统一走 OpenAI 兼容接口；新增厂商只需加一组 MODEL{n}_*，无需改代码。
# ===========================================================================

# ---------- 模型 1：（默认对话 / 裁判 / 合成）----------
MODEL1_NAME=chatgpt
MODEL1_BASE_URL=
MODEL1_API_KEY=your-openai-key
MODEL1_TEMPERATURE=0.7
MODEL1_TIMEOUT=60

# ---------- 模型 2：----------
MODEL2_NAME=chatgpt
MODEL2_BASE_URL=    # 以你账号实际的 OpenAI 兼容端点为准
MODEL2_API_KEY=your-openai-key

# ---------- 模型 3----------
MODEL3_NAME=chatgpt
MODEL3_BASE_URL=  # 填你实际的兼容端点
MODEL3_API_KEY=your-openai-key
# 若某模型不支持 OpenAI 原生 function-calling，关掉它的工具（联网时该模型将直接作答，
# 未来可改接 Hermes 文本工具调用）：
# MODEL3_SUPPORTS_TOOLS=false

# ---------- 角色与默认行为 ----------
DEFAULT_MODEL=model1                # 普通对话用哪个模型
JUDGE_MODEL=model1                  # 裁判用哪个模型（建议够用但更省的）
SYNTHESIZER_MODEL=model1            # 合成用哪个模型
DEFAULT_PANEL=model1,model2,model3  # /fusionmodel、/fusionweb 默认面板

# ===========================================================================
# v2：面板模型联网（搜索后端可插拔，策略模式）
# 填了哪个 provider 的 *_API_KEY 就能用哪个；SEARCH_PROVIDER 选默认，运行时 /search 可切。
# 新增搜索后端：在 search_providers.py 写个实现类并 register_provider，再在这里配 key。
# ===========================================================================
SEARCH_PROVIDER=tavily              # tavily | bocha
TAVILY_API_KEY=tvly-your-key
# BOCHA_API_KEY=sk-your-bocha-key
# 可选：自定义 / 自建端点（不填用官方默认）
# TAVILY_BASE_URL=https://api.tavily.com
# BOCHA_BASE_URL=https://api.bochaai.com

WEB_MAX_STEPS=4                     # 单个面板 agent 最多工具调用轮数（防止无限循环）
WEB_MAX_RESULTS=5                   # 每次 web_search 返回结果数
