# ===========================================================================
# Fusion Agent 配置示例
# 用法：复制本文件为 .env，再填入真实 key   ->   cp .env.example .env
# 程序从 MODEL1 开始递增扫描 MODEL{n}_NAME，直到某个序号缺失为止。
# 所有模型统一走 OpenAI 兼容接口；新增厂商只需加一组 MODEL{n}_*，无需改代码。
# ===========================================================================

# ---------- 模型 1：DeepSeek（默认对话 / 裁判 / 合成）----------
MODEL1_NAME=deepseek-v4-pro
MODEL1_BASE_URL=https://api.deepseek.com/v1
MODEL1_API_KEY=sk-your-deepseek-key
MODEL1_TEMPERATURE=0.7
MODEL1_TIMEOUT=60

# ---------- 模型 2：MiniMax ----------
MODEL2_NAME=minimax-m3
MODEL2_BASE_URL=https://api.minimaxi.com/v1     # 以你账号实际的 OpenAI 兼容端点为准
MODEL2_API_KEY=your-minimax-key

# ---------- 模型 3：MiMo（小米）----------
MODEL3_NAME=mimo-v2.5-pro
MODEL3_BASE_URL=https://your-mimo-openai-endpoint/v1   # 填你实际的兼容端点
MODEL3_API_KEY=your-mimo-key
# 若某模型不支持 OpenAI 原生 function-calling，关掉它的工具（联网时该模型将直接作答，
# 未来可改接 Hermes 文本工具调用）：
# MODEL3_SUPPORTS_TOOLS=false

# ---------- 角色与默认行为 ----------
DEFAULT_MODEL=model1                # 普通对话用哪个模型
JUDGE_MODEL=model1                  # 裁判用哪个模型（建议够用但更省的）
SYNTHESIZER_MODEL=model1            # 合成用哪个模型
SUMMARY_MODEL=model1                # 压缩普通对话历史用哪个模型（建议选便宜的）
DEFAULT_PANEL=model1,model2,model3  # /fusionmodel、/fusionweb 默认面板

# ---------- 普通对话上下文管理（滚动摘要 + 最近 N 轮）----------
# 逐字历史超过 CHAT_HISTORY_CHAR_BUDGET 个字符时，把"最近 N 条之外"的较早对话
# 用 SUMMARY_MODEL 压成一段记忆(system 注入)，最近 CHAT_HISTORY_KEEP_RECENT 条保留原文。
# 运行时 /context 查看记忆与占用，/reset 连记忆一起清空。
CHAT_HISTORY_CHAR_BUDGET=8000
CHAT_HISTORY_KEEP_RECENT=6

# ---------- 裁判输入上限（防长答案 / 多信源撑爆裁判上下文）----------
# 每个面板回答超过 JUDGE_ANSWER_CHAR_LIMIT 字符就头+尾截断（保留开头主张与结尾结论）；
# 喂给裁判的信源最多 JUDGE_EVIDENCE_MAX_ITEMS 条。两者填 0 表示不限。
JUDGE_ANSWER_CHAR_LIMIT=4000
JUDGE_EVIDENCE_MAX_ITEMS=24

# ===========================================================================
# v2：面板模型联网（搜索后端可插拔，策略模式）
# 填了哪个 provider 的 *_API_KEY 就能用哪个；SEARCH_PROVIDER 选默认，运行时 /search 可切。
# 新增搜索后端：在 search_providers.py 写个实现类并 register_provider，再在这里配 key。
# ===========================================================================
SEARCH_PROVIDER=tavily              # tavily | bocha
TAVILY_API_KEY=tvly-your-key
# BOCHA_API_KEY=sk-your-bocha-key
# 可选：自定义 / 自建端点（不填用官方默认）
# TAVILY_BASE_URL=https://api.tavily.com
# BOCHA_BASE_URL=https://api.bochaai.com

WEB_MAX_STEPS=4                     # 单个面板 agent 最多工具调用轮数（防止无限循环）
WEB_MAX_RESULTS=5                   # 每次 web_search 返回结果数

# ===========================================================================
# v0.4：Agent 策略（反思 Reflexion + 语义路由）
# ===========================================================================
# 反思：联网 agent 出初稿后，对照检索到的证据自检、剔除/修正无支撑的主张，再产出修订版。
# 默认关（每启用一次额外一次模型调用）；联网单模型与 Fusion 联网面板都会受益。
# REFLEXION_ENABLED=false
# REFLEXION_MAX_ROUNDS=1             # 修订轮数（draft→revise 迭代次数）

# 语义路由：CLI 用 /auto、Web 勾「自动选择」开启后，自动判定走 直答 / 联网单模型 / 离线 Fusion。
# 路由分类器用哪个模型（建议便宜的）；不填回退 SUMMARY_MODEL / DEFAULT_MODEL。
# ROUTER_MODEL=model1

# ===========================================================================
# 5.3：本地 RAG（向量库 + 嵌入；agent 的 local_search 工具，"向内看"，默认关）
# 开启后：先 `python ingest.py` 把 RAG_DOCS_DIR 下的 .md/.txt/.pdf 建索引；
# 再在 Web 勾「本地知识库」或 CLI 用 `/kb <问题>`，即以 local_search 检索本地资料作答。
# ===========================================================================
# RAG_ENABLED=true
# 嵌入模型（OpenAI 兼容端点；BASE_URL/API_KEY 不填则复用 DEFAULT_MODEL 的）
# EMBED_MODEL=text-embedding-3-small
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-your-embed-key
# RAG_DOCS_DIR=docs              # 待索引的本地文档目录
# RAG_DB_PATH=rag_chroma         # 向量库持久化目录
# RAG_COLLECTION=fusion_kb
# RAG_TOP_K=5                    # 每次 local_search 召回片段数
# RAG_CHUNK_SIZE=1000            # 分块字符数
# RAG_CHUNK_OVERLAP=150
# RAG_STORE=chroma               # 向量库后端（chroma）

# ===========================================================================
# Web「⚙️ 设置」页：在界面里改模型/参数会写入 user_settings.json（覆盖层，启动叠加在 .env 上，
# 不改本文件）。该文件可能含 API Key，已被 .gitignore 忽略。自定义路径：
# FUSION_SETTINGS=user_settings.json
# ===========================================================================
